{"version": 2, "width": 100, "height": 30, "title": "Serial Tether demo", "env": {"TERM": "xterm-256color", "SHELL": "/bin/zsh"}}
[0.3, "o", "\u001b[2m# Serial Tether \u2014 one daemon, multiple clients on a single serial port\u001b[0m\r\n"]
[1.0, "o", "\u001b[1m\u001b[32m$ \u001b[0m"]
