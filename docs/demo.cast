[5.1, "o", "\r\n"]
[5.14, "o", "\u001b[1mSerial Tether 0.5.0\u001b[0m\r\n"]
[5.18, "o", "  device     /dev/ttys001 @ 115200 baud\r\n"]
[5.22, "o", "  buffer     64 KiB\r\n"]
[5.26, "o", "  auth       \u001b[33mda3e2d294d9d4d6f942d61f0c402938a\u001b[0m\r\n"]
[5.3, "o", "             \u001b[2m(clients: TETHER_AUTH_TOKEN=...)\u001b[0m\r\n"]
[5.34, "o", "\r\n"]
[5.38, "o", "Listening:\r\n"]
[5.42, "o", "  unix       /tmp/tetherd.sock\r\n"]
[5.46, "o", "  tcp        0.0.0.0:5557    \u001b[2m(auth required)\u001b[0m\r\n"]
[5.5, "o", "               reachable as:\r\n"]
[5.54, "o", "                 \u001b[36mtcp://127.0.0.1:5557\u001b[0m   (lo0)\r\n"]
[5.58, "o", "                 \u001b[36mtcp://192.168.1.42:5557\u001b[0m   (en0)\r\n"]
[5.62, "o", "\r\n"]
[7.12, "o", "\u001b[2m# In another terminal \u2014 `tether` alone drops into a tio-style shell\u001b[0m\r\n"]
[7.62, "o", "\u001b[1m\u001b[32m$ \u001b[0m"]
